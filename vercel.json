{
  "rewrites": [
    {
      "source": "/schedule(.*)",
      "destination": "http://mod.kubg.edu.ua/cgi-bin/timetable.cgi$1"
    },
    {
      "source": "/api/proxy(.*)",
      "destination": "http://mod.kubg.edu.ua/cgi-bin/timetable.cgi$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "http://mod.kubg.edu.ua/cgi-bin/timetable.cgi"
    }
  ]
}
